VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# VITE_API_URL — DO NOT SET THIS on Vercel or in production.
# Leave it unset so /api/* routes go through vercel.json rewrites automatically.
# Only set it if running a separate local Express backend: VITE_API_URL=http://localhost:5000
